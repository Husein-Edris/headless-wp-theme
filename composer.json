{
    "name": "headless-pro/theme-tests",
    "description": "PHPUnit test suite for the Headless Pro WordPress theme",
    "type": "project",
    "license": "proprietary",
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "wp-phpunit/wp-phpunit": "^6.7",
        "yoast/phpunit-polyfills": "^2.0"
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite unit",
        "test:integration": "phpunit --testsuite integration"
    },
    "config": {
        "allow-plugins": {
            "phpunit/phpunit": true
        }
    }
}
